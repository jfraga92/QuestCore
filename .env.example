# Copia este ficheiro para ".env" e preenche com os valores do teu projeto Supabase.
# (Supabase Dashboard -> Project Settings -> API)

# URL do projeto (ex.: https://xxxxxxxx.supabase.co)
SUPABASE_URL=

# Chave "service_role" (secreta!). NUNCA a coloques no frontend nem no Git.
SUPABASE_SERVICE_ROLE_KEY=

# Token à tua escolha para proteger o endpoint /api/responses (ver respostas).
# Inventa uma frase longa e aleatória.
ADMIN_TOKEN=

# Porta local (o Railway define esta variável automaticamente em produção).
PORT=3000
